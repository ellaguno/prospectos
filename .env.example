# AI_PROVIDER: Which AI provider to use. Options:
#   "gemini"      - Gemini for everything
#   "openrouter"  - OpenRouter for everything
#   "hybrid"      - Gemini for discovery (Google Search), OpenRouter for extraction
AI_PROVIDER="hybrid"

# GEMINI_API_KEY: Required when AI_PROVIDER="gemini"
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENROUTER_API_KEY: Required when AI_PROVIDER="openrouter"
OPENROUTER_API_KEY=""

# OPENROUTER_MODEL: Model to use with OpenRouter (default: openrouter/free)
# "openrouter/free" auto-routes to the best available free model
OPENROUTER_MODEL="openrouter/free"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# BREVO_API_KEY: Required to send email campaigns via Brevo
BREVO_API_KEY=""

# BREVO_SENDER_EMAIL: From-address used by Brevo (must be a validated sender)
BREVO_SENDER_EMAIL=""

# BREVO_SENDER_NAME: Display name for outgoing campaign emails (default: "Prospectos CRM")
BREVO_SENDER_NAME="Prospectos CRM"
